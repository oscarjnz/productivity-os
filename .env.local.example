# Supabase (Phase 3 — auth + cloud sync)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth — same credentials you put in Supabase Auth → Providers → Google.
# Needed server-side to refresh Calendar/Gmail access tokens.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AI Chat — shipped Groq key so the chat works with zero setup for users.
# Inlined into the client bundle at build time (public by design).
# Must be present BEFORE `npm run build`. A user's own key overrides it.
NEXT_PUBLIC_GROQ_BUILTIN_KEY=

# Weather (Open-Meteo — no key required, kept here for future overrides)
NEXT_PUBLIC_DEFAULT_LAT=18.4861
NEXT_PUBLIC_DEFAULT_LON=-69.9312
NEXT_PUBLIC_DEFAULT_CITY=Santo Domingo
